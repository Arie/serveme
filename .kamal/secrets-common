# Shared secrets, sourced for every destination. Per-destination overrides
# live in .kamal/secrets.<destination>.
#
# `kamal` runs this file as a shell script; later assignments win.

# GHCR credentials. The same GH OAuth token is reused across all real regions.
# Local insecure registry (staging only) overrides this in .kamal/secrets.staging.
KAMAL_REGISTRY_PASSWORD=$(gh auth token)

# Rails master key — same encrypted credentials in the repo across all regions.
RAILS_MASTER_KEY=$(cat config/credentials/production.key)

# Redis runs on every host as a system service (or accessory for staging).
# All regions reach it via host.docker.internal. Staging overrides.
REDIS_URL=redis://host.docker.internal:6379/0
