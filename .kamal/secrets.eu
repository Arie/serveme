# EU database — system Postgres 13 on the host, peer-auth as `tf2`.
# Trust auth must be added on the Docker bridge (phase 0):
#   sudo tee -a /etc/postgresql/13/main/pg_hba.conf <<<'host serveme_production tf2 172.16.0.0/12 trust'
#   sudo systemctl reload postgresql
DATABASE_URL=postgres://tf2@host.docker.internal/serveme_production
