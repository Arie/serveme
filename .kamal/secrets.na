# NA database — system Postgres 17 on the host, peer-auth as `arie`.
# Trust auth must be added on the Docker bridge (phase 0):
#   sudo tee -a /etc/postgresql/17/main/pg_hba.conf <<<'host serveme_production arie 172.16.0.0/12 trust'
#   sudo systemctl reload postgresql
DATABASE_URL=postgres://arie@host.docker.internal/serveme_production
