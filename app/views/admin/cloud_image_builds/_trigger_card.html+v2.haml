%div{class: "v2-card mb-3", id: "trigger-card"}
  %h5{class: "font-display text-ink mb-3"}
    %i.fa.fa-play-circle
    Build new image
  - if in_progress
    %div{class: "v2-inset border border-info/30 text-info px-3 py-2 rounded-card mb-0"}
      Build ##{in_progress.id} is already running
      \(started #{time_ago_in_words(in_progress.started_at || in_progress.created_at)} ago).
      = link_to "View it →", admin_cloud_image_build_path(in_progress), class: "text-accent"
  - else
    = form_with url: admin_cloud_image_builds_path, method: :post, local: true do |f|
      .form-check.mb-2
        = f.check_box :force_pull, class: "form-check-input"
        = f.label :force_pull, "Force pull base image (docker build --pull)", class: "form-check-label"
      .form-check.mb-2
        = f.check_box :no_cache, class: "form-check-input"
        = f.label :no_cache, "Rebuild SourceMod + plugins + configs from scratch (keeps TF2 game files cached)", class: "form-check-label"
      = f.submit "Build New Image", class: "v2-btn v2-btn-primary mt-2"
