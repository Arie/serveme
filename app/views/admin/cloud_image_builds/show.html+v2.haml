- content_for(:title) { "Cloud Image Build ##{@build.id}" }

= turbo_stream_from [ @build, "output" ]
= turbo_stream_from_beta @build

%div{class: "max-w-5xl"}
  %div{class: "my-6"}
    = link_to "← Back to builds", admin_cloud_image_builds_path, class: "v2-btn v2-btn-ghost v2-btn-sm"
  = render "header", build: @build
  %div{class: "v2-card"}
    %h5{class: "font-display text-ink mb-3"} Build output
    %pre#build-output{class: "v2-inset text-sm font-mono mb-0 p-3", style: "max-height: 600px; overflow: auto;"}
      = @build.output
