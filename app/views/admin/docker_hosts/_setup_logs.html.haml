.card.mb-3{id: "setup-logs"}
  .card-body
    %h5.card-title
      %i.fa.fa-file-alt
      Recent Setup Logs
    - logs = docker_host.setup_logs.recent.limit(20)
    - if logs.empty?
      %p.text-muted.mb-0 No logs yet — provision steps will record their full output here.
    - else
      - logs.each do |log|
        %details.mb-2
          %summary.small
            - if log.success
              %i.fa.fa-check-circle.text-success.me-1
            - else
              %i.fa.fa-times-circle.text-danger.me-1
            %strong= log.label
            %span.text-muted.ms-2
              = log.created_at.to_fs(:short)
              - if log.exit_status
                = " · exit #{log.exit_status}"
          %pre.mt-2.mb-0.bg-dark.text-light.p-2.small{style: "max-height: 400px; overflow: auto;"}
            = log.output.presence || "(no output)"
