- content_for(:title) { "Edit Docker Host" }

.row
  .col-md-12.col-lg-6.offset-lg-2
    %h2 Edit Docker Host

.row
  .col-md-12.col-lg-6.offset-lg-2
    = simple_form_for([:admin, @docker_host], wrapper: :horizontal_form, html: { class: 'form-horizontal docker_host' }) do |f|
      = render 'form', f: f

      .row.submit-row
        .col-lg-2
          %button.btn.btn-warning{type: :submit, data: { disable_with: "Saving..."}}
            Save
        .col-lg-2
          = link_to "Cancel", admin_docker_hosts_path, class: "btn btn-secondary"
