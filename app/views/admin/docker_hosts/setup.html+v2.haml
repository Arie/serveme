- content_for(:title) { "Setup #{@docker_host.hostname}" }

= turbo_stream_from_beta "docker_host_setup_#{@docker_host.id}"

%div{class: "max-w-4xl"}
  %div{class: "flex items-center justify-between gap-4 my-6 flex-wrap"}
    %div
      %h1{class: "v2-page-title"} Setup: #{@docker_host.hostname}
      %div{class: "v2-breadcrumb"} Docker Hosts / Setup
    = link_to "Back to Docker Hosts", admin_docker_hosts_path, class: "v2-btn v2-btn-ghost v2-btn-sm"

  %div{class: "v2-card mb-3"}
    %h5{class: "font-display text-ink mb-3"} Host Details
    %div{class: "v2-table-wrap"}
      %table{class: "v2-table"}
        %tbody
          %tr
            %td{class: "text-muted"} Hostname
            %td{class: "font-mono"}= @docker_host.hostname
          %tr
            %td{class: "text-muted"} IP Address
            %td{class: "font-mono"}= @docker_host.ip || "Pending (will be assigned by Hetzner)"
          - if @docker_host.provider?
            %tr
              %td{class: "text-muted"} Provider
              %td= @docker_host.provider.titleize
            %tr
              %td{class: "text-muted"} Provider Location
              %td= CloudProvider::Hetzner::LOCATIONS.dig(@docker_host.provider_location, :name) || @docker_host.provider_location
          %tr
            %td{class: "text-muted"} City
            %td= @docker_host.city
          %tr
            %td{class: "text-muted"} Location
            %td
              %span{class: ["flags", "flags-#{@docker_host.location.flag}"]}
              = @docker_host.location.name
          %tr
            %td{class: "text-muted"} Setup Status
            %td
              = render partial: "admin/docker_hosts/setup_status", locals: { docker_host: @docker_host }

  - step_number = 0
  - dns_description = @docker_host.serveme_hostname? ? "Create/update A record in Cloudflare for #{@docker_host.hostname}" : "Verify that #{@docker_host.hostname} resolves to #{@docker_host.ip || 'the assigned IP'}"

  %div
    - if @docker_host.hetzner?
      - step_number += 1
      = render partial: "admin/docker_hosts/setup_step", locals: { docker_host: @docker_host, key: "create_vm", title: "#{step_number}. Create Hetzner VM", icon: "fa-cloud", description: "Create a #{CloudProvider::Hetzner::LOCATIONS.dig(@docker_host.provider_location, :server_type) || 'cpx22'} server in #{CloudProvider::Hetzner::LOCATIONS.dig(@docker_host.provider_location, :name) || @docker_host.provider_location}" }
    - step_number += 1
    = render partial: "admin/docker_hosts/setup_step", locals: { docker_host: @docker_host, key: "dns", title: "#{step_number}. DNS Configuration", icon: "fa-globe", description: dns_description }
    - step_number += 1
    = render partial: "admin/docker_hosts/setup_step", locals: { docker_host: @docker_host, key: "ssh", title: "#{step_number}. SSH Connectivity", icon: "fa-terminal", description: "Test SSH connection to #{@docker_host.ip || 'the server'} using the serveme public key" }
    - step_number += 1
    = render partial: "admin/docker_hosts/setup_step", locals: { docker_host: @docker_host, key: "provision", title: "#{step_number}. Host Provisioning", icon: "fa-server", description: "Install Docker, Caddy (reverse proxy with auto-SSL), and websocket echo server" }
    - step_number += 1
    = render partial: "admin/docker_hosts/setup_step", locals: { docker_host: @docker_host, key: "ssl", title: "#{step_number}. SSL Verification", icon: "fa-lock", description: "Verify HTTPS is working on #{@docker_host.hostname} (Caddy auto-provisions Let's Encrypt cert)" }
    - step_number += 1
    = render partial: "admin/docker_hosts/setup_step", locals: { docker_host: @docker_host, key: "pull_image", title: "#{step_number}. Pull Docker Image", icon: "fa-download", description: "Pull serveme/tf2-cloud-server:latest and mark host as ready" }

  %div
    = render partial: "admin/docker_hosts/setup_logs", locals: { docker_host: @docker_host }
