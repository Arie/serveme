- content_for :title, "League Maps Preview"

%div{class: "flex items-center justify-between gap-4 my-6 flex-wrap"}
  %div
    %h1{class: "v2-page-title"} League Maps Preview
    %div{class: "v2-breadcrumb"} Admin / League Maps / Preview
  = link_to "← Back to League Maps", admin_league_maps_path, class: "v2-btn v2-btn-outline"

- if @validation_result[:valid]
  %div{class: "v2-card border border-success/40 mb-4"}
    %h5{class: "font-display text-success-text mb-1"} ✓ Configuration Valid
    %p{class: "mb-0 text-muted"} The fetched configuration passed all validation checks and is ready to apply.

  - if @validation_result[:warnings].any?
    %div{class: "v2-card border border-gold/40 mb-4"}
      %h6{class: "font-display text-gold mb-2"} Warnings:
      %ul{class: "mb-0 list-disc pl-5 text-gold"}
        - @validation_result[:warnings].each do |warning|
          %li= warning
- else
  %div{class: "v2-card border border-danger/40 mb-4"}
    %h5{class: "font-display text-danger mb-1"} ✗ Configuration Invalid
    %p{class: "text-muted"} The fetched configuration has validation errors and cannot be applied:
    %ul{class: "mb-0 list-disc pl-5 text-danger"}
      - @validation_result[:errors].each do |error|
        %li= error

  %div{class: "mt-3"}
    = link_to "Back to Management", admin_league_maps_path, class: "v2-btn v2-btn-outline"

- if @validation_result[:valid]
  %div{class: "grid md:grid-cols-2 gap-4 mb-4"}
    %div{class: "v2-card"}
      %h5{class: "font-display text-ink mb-3"} Changes Summary
      - if @diff[:added_leagues].any?
        %h6{class: "font-display text-success-text mb-1"} Added Leagues:
        %ul{class: "list-disc pl-5"}
          - @diff[:added_leagues].each do |league_name|
            %li{class: "text-success-text"}= league_name

      - if @diff[:removed_leagues].any?
        %h6{class: "font-display text-danger mb-1"} Removed Leagues:
        %ul{class: "list-disc pl-5"}
          - @diff[:removed_leagues].each do |league_name|
            %li{class: "text-danger"}= league_name

      - if @diff[:modified_leagues].any?
        %h6{class: "font-display text-gold mb-1"} Modified Leagues:
        %ul{class: "list-disc pl-5"}
          - @diff[:modified_leagues].each do |league|
            %li{class: "text-gold"}
              %strong= league[:name]
              - if league[:added_maps].any?
                %br
                %small{class: "text-success-text font-mono"}
                  + #{league[:added_maps].join(', ')}
              - if league[:removed_maps].any?
                %br
                %small{class: "text-danger font-mono"}
                  - #{league[:removed_maps].join(', ')}

      - if @diff[:added_leagues].empty? && @diff[:removed_leagues].empty? && @diff[:modified_leagues].empty?
        %p{class: "text-muted"} No changes detected

    %div{class: "v2-card"}
      %h5{class: "font-display text-ink mb-3"} Apply Configuration
      %p{class: "text-muted"} Apply the fetched configuration to make it active instantly in this region.

      = form_with url: apply_admin_league_maps_path, method: :post, local: true do |f|
        = f.hidden_field :config, value: @new_config.to_json
        = f.submit "Apply Configuration",
                  class: "v2-btn v2-btn-primary",
                  data: { confirm: "This will update the league maps configuration immediately. Continue?" }

      %div{class: "mt-2"}
        = link_to "Cancel", admin_league_maps_path, class: "v2-btn v2-btn-outline"

  %div{class: "v2-card"}
    %h5{class: "font-display text-ink mb-3"} New Configuration Preview
    - new_leagues = @new_config.dig("league_maps") || []
    - if new_leagues.any?
      %div{class: "grid md:grid-cols-2 gap-4"}
        - new_leagues.each do |league|
          %div{class: "v2-inset"}
            %div{class: "flex items-center flex-wrap gap-2 mb-2"}
              %h6{class: "font-display text-ink font-bold mb-0"}= league["name"]
              %span{class: "v2-badge v2-badge-info"}= pluralize((league["maps"] || []).size, 'map')
              - unless league["active"] != false
                %span{class: "v2-badge v2-badge-gold"} Inactive
            %div{class: "flex flex-wrap gap-1"}
              - (league["maps"] || []).each do |map_name|
                - if map_name.start_with?('koth_')
                  %span{class: "v2-badge v2-badge-gold font-mono"}= map_name
                - elsif map_name.start_with?('cp_')
                  %span{class: "v2-badge font-mono"}= map_name
                - elsif map_name.start_with?('pl_')
                  %span{class: "v2-badge v2-badge-success font-mono"}= map_name
                - elsif map_name.start_with?('ulti_', 'ultiduo_')
                  %span{class: "v2-badge v2-badge-danger font-mono"}= map_name
                - elsif map_name.start_with?('pass_')
                  %span{class: "v2-badge v2-badge-info font-mono"}= map_name
                - else
                  %span{class: "v2-badge font-mono"}= map_name
    - else
      %div{class: "v2-card border border-gold/40 text-gold"} No leagues found in fetched configuration.
