- content_for(:title) { "Live Scoreboards" }

%div{class: "my-6"}
  %h1{class: "v2-page-title"}
    Live Scoreboards
    %small{class: "text-muted font-mono ml-2"}= "(#{@reservations.size} active)"

- @reservations.each do |reservation|
  - live_stats = LiveMatchStats.get_stats(reservation.id)
  = turbo_stream_from_beta reservation

  %div{class: "v2-card mb-4 p-0"}
    %div{class: "flex items-center justify-between gap-4 flex-wrap px-4 py-3 border-b border-white/10"}
      %div
        %strong= reservation.server.name
        %span{class: "text-muted ml-2 font-mono"}= reservation.first_map
        %small{class: "text-muted ml-2"}
          by
          = link_to reservation.user.nickname, reservation.user.steam_profile_url, target: "_blank", class: "text-accent-light hover:underline"
      %div{class: "flex items-center gap-2"}
        = link_to rcon_reservation_path(reservation), class: "v2-btn v2-btn-outline v2-btn-sm", target: "_blank" do
          %i.fa.fa-terminal
          RCON
        = link_to reservation_path(reservation), class: "v2-btn v2-btn-info v2-btn-sm" do
          %i.fa.fa-eye
          Show
    %div{class: "p-2"}
      %div{id: "match-scoreboard-#{reservation.id}"}
        - if live_stats&.any?
          - reservation_players_by_uid = reservation.reservation_players.index_by(&:steam_uid)
          - connection_info = ScoreboardConnectionInfo.for_reservation(reservation)
          - live_stats.each do |match_stats|
            = render "reservations/match_scoreboard", live_stats: match_stats, reservation_players_by_uid: reservation_players_by_uid, connection_info: connection_info
        - else
          %p{class: "text-muted mb-0"} No match data yet
