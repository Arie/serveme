- content_for(:title) { "Edit #{@user.nickname}" }

%div{class: "flex items-center justify-between gap-4 my-6 flex-wrap"}
  %h1{class: "v2-page-title"} Edit User: #{@user.nickname}
  = link_to "Back to User", admin_user_path(@user), class: "v2-btn v2-btn-outline"

%div{class: "grid grid-cols-1 md:grid-cols-2 gap-4"}
  %div{class: "v2-card"}
    %h5{class: "text-ink font-display mb-3"} User Information
    = form_with model: [:admin, @user], local: true do |f|
      %div{class: "form-group"}
        = f.label :name, class: "v2-label"
        = f.text_field :name, class: "v2-input"

      %div{class: "form-group mt-3"}
        = f.label :nickname, class: "v2-label"
        = f.text_field :nickname, class: "v2-input"

      = f.submit "Update User", class: "v2-btn v2-btn-primary mt-3"

  %div{class: "v2-card"}
    %h5{class: "text-ink font-display mb-3"} Group Management
    %h6{class: "text-ink font-display"} Current Groups
    - if @user_groups.any?
      %ul{class: "flex flex-col gap-2 mb-3"}
        - @user_groups.each do |group_user|
          - next unless group_user.group
          %li{class: "v2-inset p-3 flex items-center justify-between gap-3"}
            %div
              %strong= group_user.group.name
              - if group_user.expires_at
                %br
                %small{class: "text-muted font-mono"}
                  Expires: #{l(group_user.expires_at, format: :long)}
            %div{class: "flex items-center gap-2"}
              - if group_user.expires_at
                %button{class: "v2-btn v2-btn-outline v2-btn-sm", "data-bs-toggle" => "modal", "data-bs-target" => "#updateExpiryModal#{group_user.id}", type: "button"}
                  Update Expiry
              = form_with url: admin_user_path(@user), method: :patch, local: true do |f|
                = hidden_field_tag :group_action, "remove"
                = hidden_field_tag :group_id, group_user.group_id
                = f.submit "Remove", class: "v2-btn v2-btn-danger v2-btn-sm", data: { confirm: "Remove user from #{group_user.group.name}?" }

          - if group_user.expires_at
            .modal.fade{id: "updateExpiryModal#{group_user.id}", tabindex: "-1", role: "dialog"}
              .modal-dialog{role: "document"}
                .modal-content
                  %div{data: {
                         controller: "date-extension",
                         "date-extension-format-value": I18n.t('time.formats.javascript_datepicker'),
                         "date-extension-show-meridian-value": I18n.t(:show_meridian, :scope => :time)
                       }}
                    = form_with url: admin_user_path(@user), method: :patch, local: true do |f|
                      .modal-header
                        %h5.modal-title Update Expiry for #{group_user.group.name}
                        %button.btn-close{"data-bs-dismiss" => "modal", type: "button", "aria-label" => "Close"}
                      .modal-body
                        = hidden_field_tag :group_action, "update_expiry"
                        = hidden_field_tag :group_user_id, group_user.id
                        %div{class: "form-group"}
                          = label_tag :expires_at, "Expires At", class: "v2-label"
                          = datetime_field_tag :expires_at,
                            group_user.expires_at&.strftime("%Y-%m-%dT%H:%M"),
                            class: "v2-input",
                            "data-date-extension-target": "dateInput"

                        %div{class: "form-group mt-3"}
                          %label{class: "v2-label"} Quick duration presets (extends from current expiry)
                          %div{class: "flex flex-wrap gap-2"}
                            %button{class: "v2-btn v2-btn-outline v2-btn-sm", type: "button",
                                                   "data-action" => "date-extension#extendDate",
                                                   "data-days" => "31"}
                              +1 month
                            %button{class: "v2-btn v2-btn-outline v2-btn-sm", type: "button",
                                                   "data-action" => "date-extension#extendDate",
                                                   "data-days" => "93"}
                              +3 months
                            %button{class: "v2-btn v2-btn-outline v2-btn-sm", type: "button",
                                                   "data-action" => "date-extension#extendDate",
                                                   "data-days" => "186"}
                              +6 months
                            %button{class: "v2-btn v2-btn-outline v2-btn-sm", type: "button",
                                                   "data-action" => "date-extension#extendDate",
                                                   "data-days" => "365"}
                              +1 year
                            %button{class: "v2-btn v2-btn-ghost v2-btn-sm", type: "button",
                                                     "data-action" => "date-extension#clearDate"}
                              Never expires
                      .modal-footer
                        %button{class: "v2-btn v2-btn-outline v2-btn-sm", "data-bs-dismiss" => "modal", type: "button"} Cancel
                        = f.submit "Update", class: "v2-btn v2-btn-primary v2-btn-sm"
    - else
      %p{class: "text-muted"} User is not in any groups

    %hr{class: "border-white/10 my-4"}

    %h6{class: "text-ink font-display"} Add to Group
    %div{data: {
           controller: "date-extension",
           "date-extension-format-value": I18n.t('time.formats.javascript_datepicker'),
           "date-extension-show-meridian-value": I18n.t(:show_meridian, :scope => :time)
         }}
      = form_with url: admin_user_path(@user), method: :patch, local: true do |f|
        = hidden_field_tag :group_action, "add"
        %div{class: "form-group"}
          = select_tag :group_id,
            options_for_select(@groups.reject { |g| @user.groups.include?(g) }.map { |g| [g.name, g.id] }),
            class: "v2-select",
            prompt: "Select a group..."

        %div{class: "form-group mt-3"}
          = label_tag :expires_at, "Expires At (optional)", class: "v2-label"
          = datetime_field_tag :expires_at, nil,
            class: "v2-input",
            "data-date-extension-target": "dateInput"
          %small{class: "v2-help"} Leave blank for permanent membership

        %div{class: "form-group mt-3"}
          %label{class: "v2-label"} Quick duration presets
          %div{class: "flex flex-wrap gap-2"}
            %button{class: "v2-btn v2-btn-outline v2-btn-sm", type: "button",
                                   "data-action" => "date-extension#extendDate",
                                   "data-days" => "31"}
              +1 month
            %button{class: "v2-btn v2-btn-outline v2-btn-sm", type: "button",
                                   "data-action" => "date-extension#extendDate",
                                   "data-days" => "93"}
              +3 months
            %button{class: "v2-btn v2-btn-outline v2-btn-sm", type: "button",
                                   "data-action" => "date-extension#extendDate",
                                   "data-days" => "186"}
              +6 months
            %button{class: "v2-btn v2-btn-outline v2-btn-sm", type: "button",
                                   "data-action" => "date-extension#extendDate",
                                   "data-days" => "365"}
              +1 year
            %button{class: "v2-btn v2-btn-ghost v2-btn-sm", type: "button",
                                     "data-action" => "date-extension#clearDate"}
              Never expires

        = f.submit "Add to Group", class: "v2-btn v2-btn-primary mt-3"
