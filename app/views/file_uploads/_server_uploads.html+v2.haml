%div{id: "file_uploads_#{@file_upload.id}_server_uploads"}
  %div{class: "v2-table-wrap"}
    %table{class: "v2-table"}
      %thead
        %tr
          %th Server
          %th Status
      %tbody
        - @servers.each do |server|
          - server_upload = @file_upload.server_uploads.find {|su| su.server_id == server.id }
          - if server_upload
            = render 'server_uploads/server_upload', server_upload: server_upload
          - else
            = render 'server_uploads/server', file_upload: @file_upload, server: server.decorate
