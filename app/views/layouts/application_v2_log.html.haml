!!!
%html
  %head
    - subtitle = content_for(:title) || "free TF2 server reservations"
    %title #{SITE_HOST} - #{subtitle}
    = stylesheet_link_tag v2_stylesheet_href, skip_pipeline: true, media: "all", data: { turbo_track: "reload" }
    = stylesheet_link_tag "v2_log", media: "all", data: { turbo_track: "reload" }
    = stylesheet_link_tag "v2_extras", media: "all", data: { turbo_track: "reload" }
    = content_for(:stripe)
    = javascript_importmap_tags("application")
    = javascript_include_tag "serveme"
    = csrf_meta_tags
    %meta{name: "time-zone", content: Time.zone.tzinfo.identifier}
    = render 'shared/analytics'
    %meta{name: "viewport", content: "width=device-width, initial-scale=1.0, shrink-to-fit=no"}
    %meta{name: "description", content: "Free TF2 servers, ready for action in 60 seconds!"}
    = content_for(:head)
  %body{class: "bg-page text-ink font-sans antialiased"}
    = render 'shared/navigation'
    .container-fluid
      %main{role: "main"}
        - if notice || alert
          %div{class: "my-2"}
            = render 'shared/flash'
        = yield
      = render 'shared/timezone'
