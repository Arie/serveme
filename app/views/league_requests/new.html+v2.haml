%div{class: "flex items-center justify-between gap-4 my-6 flex-wrap"}
  %h1{class: "v2-page-title"} League request search

%div{class: "v2-card max-w-2xl"}
  = simple_form_for(@league_request, url: league_request_path, data: { turbo: false } ) do |f|

    = f.input :ip,              label: "IP", as: :string,  placeholder: "IPv4 address"
    = f.input :steam_uid,       label: "Steam ID 64", as: :string,  placeholder: "SteamID64"
    = f.input :reservation_ids, label: "Limit to reservation IDs", as: :string,  placeholder: "123456,123457,123458"
    = f.input :cross_reference, label: "Cross reference results", as: :boolean, placeholder: "Cross reference found matches (can cause loads of results, be careful for false positives)"
    = f.input :include_vpn_results, label: "Include VPN results", as: :boolean, placeholder: "Include VPN/hosting provider IPs in cross-reference results (more results but higher false positive risk)"

    %div{class: "mt-4"}
      %button{type: :submit, class: "v2-btn v2-btn-primary"}
        Search
