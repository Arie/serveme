%div{class: "v2-table-wrap"}
  %table{class: "v2-table logs"}
    %thead
      %tr
        %th Filename
        %th Title
        %th Map
        %th Upload status
    %tbody
      - @log_uploads.each do |upload|
        %tr
          %td{class: "font-mono"}
            - if upload.url
              = link_to(upload.file_name, upload.url, :target => '_blank')
            - else
              = upload.file_name
          %td= upload.title
          %td
            %span.map-name-compact{data: {bs_toggle: "tooltip", bs_placement: "top"}, title: upload.map_name}= upload.map_name
          %td= upload.status
