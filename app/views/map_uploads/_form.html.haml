%div{data: { controller: 'map-upload' }}
  = simple_form_for(@map_upload, :html => { :class => 'form-inline' }, data: { turbo: false, action: 'submit->map-upload#handleSubmit' } ) do |f|
    = f.input :file, :as => :file, :label => false, :placeholder => 'Map file, .bsp only', input_html: { data: { 'map-upload-target': 'fileInput' } }
    %button.btn.btn-primary{:type => :submit, data: { 'map-upload-target': 'submitButton' }}
      Upload

  .upload-progress.mt-3.d-none{data: { 'map-upload-target': 'progressContainer' }}
    .progress.w-100.upload-progress-bar
      .progress-bar.progress-bar-striped.progress-bar-animated.bg-success{role: "progressbar", "aria-valuenow": "0", "aria-valuemin": "0", "aria-valuemax": "100", data: { 'map-upload-target': 'progressBar' }}
        %strong{data: { 'map-upload-target': 'progressText' }} 0%