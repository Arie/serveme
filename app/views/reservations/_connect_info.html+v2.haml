%div{id: "reservation_connect_info_#{reservation.id}", class: "flex flex-wrap items-center gap-2"}
  - connect = reservation.connect_string
  - if connect.present?
    - if reservation&.server&.sdr? && preliminary_sdr?(reservation)
      %span{class: "text-faint text-xs w-full"} Temporary connect info
    %span{class: "v2-connect"}= connect
    = render 'shared/copy_button', :copy_button_id => "connect_string", :copy_text => connect
  - elsif reservation.past?
    %span{class: "text-faint"} &mdash;
  - else
    %span{class: "text-faint inline-flex items-center gap-1"}
      %i.fa.fa-clock-o
      Not available yet
