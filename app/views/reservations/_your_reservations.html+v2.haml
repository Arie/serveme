%div{class: "flex items-center justify-between gap-4 my-6 flex-wrap"}
  %div
    - if @target_user && @target_user != current_user
      %h1{class: "v2-page-title"}
        = @target_user.nickname
        - if @target_user.nickname&.end_with?('s')
          ' reservations
        - else
          's reservations
    - else
      %h1{class: "v2-page-title"} Your reservations
  = link_to "New reservation", new_reservation_path, class: "v2-btn v2-btn-primary"

%div{class: "text-center my-4"}
  != @pagy.series_nav(:bootstrap)

= render 'users_reservations'
