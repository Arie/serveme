= turbo_stream_from_beta @reservation

- title = "Reservation: #{reservation.to_s}"
- content_for :title do
  = title
- content_for :meta_description do
  = title

- content_for :head do
  = render "shared/meta_tags", title: title, description: title, url: reservation_url(reservation)

%div{class: "flex items-center justify-between gap-4 my-6 flex-wrap"}
  %div
    %h1{class: "v2-page-title"}
      Reservation:
      %span{class: "font-mono"}= reservation.to_s
  - clone_identifier = "#{[reservation&.server_config&.file, reservation&.first_map, (reservation&.whitelist&.file || reservation&.custom_whitelist_id)].reject(&:blank?).join(' | ')}"
  = link_to new_reservation_path(reservation.template_attributes), class: 'v2-btn v2-btn-primary', title: "Clone this reservation: #{clone_identifier}", alt: clone_identifier do
    %i.fa.fa-clone
    Clone

- if reservation&.server&.sdr?
  %div{class: "v2-card border-l-4 border-l-gold mb-4 text-muted"}
    This is a server hosted on Valve's SDR network. A special kind of VPN to improve pings and defend against DDoS attacks.
    %br
    SDR servers can't be used for TF2Center/TF2Stadium and you can only use RCON with the !rcon chat command
    %br
    Use the connect command in TF2 console to connect to the server.

%div{class: "flex flex-col gap-6"}
  %div{class: "flex flex-col gap-6"}
    %div{class: "v2-card border-l-4 border-l-accent"}
      %h3{class: "font-display text-lg font-bold text-ink mb-3"} Connect info
      = render "connect_info"

    %div{class: "v2-card"}
      %div{class: "v2-table-wrap"}
        %table{class: "v2-table"}
          - if current_user.admin? || current_user.league_admin? || current_user.streamer?
            %tr
              %td Reserved by
              %td
                = link_to(reservation.user.nickname, reservation.user.steam_profile_url, target: "_blank", class: "player-name")
          %tr
            %td Status
            %td
              = render "status"

          %tr
            %td Actions
            %td.actions= render 'actions'

          - if reservation.now?
            %tr
              %td Server control
              %td
                %div{class: "flex flex-wrap gap-2"}
                  = link_to "Web RCON", rcon_reservation_path(reservation), class: "v2-btn v2-btn-outline v2-btn-sm"
                  = link_to "Monitoring", server_monitoring_path(server_id: reservation.server_id), class: "v2-btn v2-btn-info v2-btn-sm", target: "_blank"

          %tr
            %td SDR connect info
            %td
              = render "sdr_connect_info"

          - if !reservation&.server&.sdr?
            %tr
              %td TF2Center info
              %td
                = render "tf2center_info"

          %tr
            %td Password
            %td
              %span{class: "font-mono text-ink"}= reservation.password

          %tr
            %td RCON
            %td
              = render "rcon_info"

          %tr
            %td TV password
            %td
              %span{class: "font-mono text-ink"}= reservation.tv_password

          %tr
            %td STV connect info
            %td
              %div{class: "flex flex-wrap items-center gap-2"}
                = render "stv_connect_info"
                - if current_admin || current_league_admin || current_streamer
                  - ip_and_port = "#{reservation&.server&.public_ip}:#{reservation&.server&.public_tv_port}"
                  - password_for_relay = reservation.tv_relaypassword.presence || reservation.tv_password
                  = link_to "http://relay.fakkelbrigade.eu/new?ip_port=#{ip_and_port}&password=#{password_for_relay}", :title => "create relay", :class => "v2-btn v2-btn-outline v2-btn-sm", :target => "_blank" do
                    Create relay
                    %i.fa.fa-share-alt

          - if reservation.server_config
            %tr
              %td Server config
              %td= reservation.server_config

          - if SiteSetting.show_democheck?
            %tr
              %td Democheck mode (required for RGL matches)
              - case reservation.democheck_mode
              - when "kick"
                %td Kick (default)
              - when "warn"
                %td{class: "text-gold"} Warn only
              - when "disable"
                %td{class: "text-danger"} Disabled

          - if reservation.custom_whitelist_id.present?
            %tr
              %td Whitelist
              %td= link_to("Custom whitelist", "http://whitelist.tf/#{reservation.custom_whitelist_id}", class: "text-info hover:brightness-110")
          - elsif reservation.whitelist
            %tr
              %td Whitelist
              %td= reservation.whitelist

          - if current_admin || current_league_admin || current_streamer
            %tr
              %td Logsecret
              %td
                %div{class: "flex flex-wrap items-center gap-2"}
                  %span{class: "v2-connect"}= reservation.logsecret
                  = render 'shared/copy_button', :copy_button_id => "logsecret_string", :copy_text => reservation.logsecret
                  - ip_and_port = "#{reservation&.server&.ip}:#{reservation&.server&.port}"
                  = link_to "http://live.fakkelbrigade.eu/matches/new?host=#{ip_and_port}&rcon=#{reservation.rcon}&logsecret=#{reservation.logsecret}", :title => "create livestats", :class => "v2-btn v2-btn-outline v2-btn-sm", :target => "_blank" do
                    Livestats
                    %i.fa.fa-bar-chart
            %tr
              %td Stats
              %td
                %div{class: "flex flex-wrap gap-2"}
                  = link_to show_reservation_statistic_path(reservation),         :title => "Player stats", :class => "v2-btn v2-btn-info v2-btn-sm" do
                    Player stats
                    %i.fa.fa-bar-chart
                  = link_to show_reservation_server_statistic_path(reservation),  :title => "Server stats", :class => "v2-btn v2-btn-primary v2-btn-sm" do
                    Server stats
                    %i.fa.fa-bar-chart

    - reservation_players_by_uid = reservation.reservation_players.index_by(&:steam_uid)
    - connection_info = ScoreboardConnectionInfo.for_reservation(reservation)
    - all_match_stats = LiveMatchStats.get_or_rebuild_stats(reservation)
    %div{id: "match-scoreboard-#{reservation.id}"}
      - if all_match_stats&.any?
        - all_match_stats.each do |match_stats|
          = render "reservations/match_scoreboard", live_stats: match_stats, reservation_players_by_uid: reservation_players_by_uid, connection_info: connection_info
      - else
        - reservation.reservation_matches.includes(:match_players).order(:match_number).each do |match|
          - match_stats = ScoreboardStats.from_match(match)
          = render "reservations/match_scoreboard", live_stats: match_stats, reservation_players_by_uid: reservation_players_by_uid, connection_info: connection_info

  %div{class: "flex flex-col gap-6"}
    %div{class: "v2-card"}
      %h3{class: "font-display text-lg font-bold text-ink mb-3"} Status log
      %div{class: "v2-table-wrap"}
        %table{class: "v2-table"}
          %tbody#reservation_statuses
            = render reservation.reservation_statuses.ordered
