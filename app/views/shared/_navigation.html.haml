.w-full.flex-none.mt-4.sm:mt-0.sm:w-auto.sm:ml-auto.flex.items-center
  - if current_user
    = link_to your_reservations_path, class: "mx-6 hover:text-gray-400" do
      %span Your reservations

    = link_to played_in_path, class: "mx-6 hover:text-gray-400" do
      %span Played

    - if current_user.admin? || current_user.league_admin? || current_user.streamer?
      = link_to recent_reservations_path, class: "mx-6 hover:text-gray-400" do
        %span.hidden.lg:inline Recent reservations

    - if current_user&.donator?
      = link_to servers_path, class: "mx-6 hover:text-gray-400" do
        %span.hidden.lg:inline Servers

  - if current_user
    = link_to settings_path, class: "group border-l pl-6 border-gray-700 hover:text-teal-400 flex items-center" do
      %span.hidden.sm:inline Settings
    = link_to users_logout_path, class: "group pl-6 border-gray-700 hover:text-teal-400 flex items-center", method: :delete do
      %span Sign out

  - else
    = link_to '/users/auth/steam', class: "group border-l pl-6 border-gray-700 hover:text-teal-400 flex items-center", method: :post do
      %span Sign in

