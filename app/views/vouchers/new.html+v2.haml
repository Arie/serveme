%div{class: "my-6"}
  %h1{class: "v2-page-title"} Claim premium code
  - if @voucher.product
    %p{class: "text-muted mt-1"}= @voucher.product.name

%div{class: "v2-card max-w-2xl"}
  %p With a premium code you can get premium status, here are the perks:

  = render "shared/perks"

%div{class: "v2-card max-w-2xl mt-4 form-inline"}
  = simple_form_for(Voucher.new, wrapper: :horizontal_form, html: { class: "form-horizontal voucher" }) do |f|
    = f.input :code, :input_html => { value: @voucher.code }, :class => "col-md-10 form-control required", autofocus: true

    .row.submit-row
      .col-lg-2.offset-lg-3
        %button{type: :submit, class: "v2-btn v2-btn-primary"}
          Claim
