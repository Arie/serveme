- content_for(:title) { "whitelists" }
%div{class: "flex items-center justify-between gap-4 my-6"}
  %h1{class: "v2-page-title"} Whitelists
  = link_to "Add whitelist", new_whitelist_path, class: "v2-btn v2-btn-primary"

%div{class: "v2-table-wrap"}
  %table{class: "v2-table"}
    %thead
      %tr
        %th File
        %th Hidden
    %tbody
      - @whitelists.each do |whitelist|
        %tr[whitelist]
          %td= link_to(whitelist.file, edit_whitelist_path(whitelist))
          %td= whitelist.hidden

- if @pagy
  %div{class: "mt-4"}
    != @pagy.series_nav(:bootstrap)
