%h1{class: "v2-page-title my-6"} New whitelist
%div{class: "v2-card max-w-2xl"}
  = simple_form_for(@whitelist, url: url_for(controller: "whitelists", action: "create"), html: { class: 'form' }) do |f|
    = f.input :file, label: "File name (including .txt)"
    = f.input :hidden
    %div{class: "mt-4"}
      %button{type: :submit, class: "v2-btn v2-btn-primary"} Save
