#!/usr/bin/env bash
# Fetch fresh GeoLite2 databases from MaxMind and roll them to every
# region. `kamal app boot` is a start-new/wait-healthy/stop-old cycle —
# zero user-visible downtime for web; sidekiq drains gracefully.
set -euo pipefail
cd "$(dirname "$0")/.."

mise x -- bundle exec rake maxmind:fetch

roll_region() {
  local region=$1 deploy_user=$2 roles=$3
  DEPLOY_SSH_USER="$deploy_user" bin/kamal-bootstrap "$region"
  mise x -- kamal app boot -d "$region" -r "$roles"
}

roll_region eu  tf2  web,sidekiq,sidekiq2,discord_bot &
roll_region na  arie web,sidekiq,sidekiq2,discord_bot &
roll_region au  tf2  web,sidekiq,discord_bot &
roll_region sea arie web,sidekiq,discord_bot &
wait
