#!/usr/bin/env ruby
# frozen_string_literal: true

require "optparse"
require "fileutils"
require "yaml"
require_relative "../lib/test_runner"
require_relative "../lib/timing"

APP_ROOT = File.expand_path("..", __dir__)

# ============================================================================
# Helper Functions
# ============================================================================

def load_config
  YAML.load_file(File.join(APP_ROOT, "config", "test_suite.yml"))
end

def detect_formatter
  return :ai if ENV["CLAUDECODE"] == "1"
  return :simple if ENV["CI"] == "true"
  return :simple if !$stdout.tty? # Piped output
  :fancy
end

def resolve_command(task_name, task_config, autocorrect:, seed: nil, verbose: false)
  command = autocorrect && task_config["autocorrect"] ? task_config["autocorrect"] : task_config["command"]

  seed_arg = seed ? " --order random:#{seed}" : ""
  debug = verbose ? "DEBUG=1 " : ""

  command % {
    seed_arg: seed_arg,
    debug: debug
  }
rescue KeyError
  # Command doesn't have interpolation placeholders, return as-is
  command
end

def resolve_dependencies(task_name, task_config)
  depends_on = task_config["depends_on"]
  return [] if depends_on.nil?

  Array(depends_on).map(&:to_sym)
end

def resolve_task_with_dependencies(task_name, config)
  tasks = config["tasks"]
  task_config = tasks[task_name]

  if task_config.nil?
    warn "Error: Task '#{task_name}' not found in configuration"
    exit 1
  end

  result = Set.new
  queue = [ task_name ]

  while queue.any?
    current_task = queue.shift
    next if result.include?(current_task)

    result.add(current_task)

    current_config = tasks[current_task]
    if current_config
      dependencies = resolve_dependencies(current_task, current_config)
      queue.concat(dependencies.map(&:to_s))
    end
  end

  result.to_a
end

def register_section_tasks(runner, config, section_tasks, autocorrect:, seed: nil, verbose: false)
  tasks = config["tasks"]

  section_tasks.each do |task_name|
    task_name_sym = task_name.to_sym
    task_config = tasks[task_name]

    if task_config.nil?
      warn "Warning: Task '#{task_name}' not found in configuration"
      next
    end

    command = resolve_command(task_name, task_config, autocorrect: autocorrect, seed: seed, verbose: verbose)
    dependencies = resolve_dependencies(task_name, task_config)
    is_autocorrect = autocorrect && task_config["autocorrect"] ? true : false

    runner.define_task(
      name: task_name_sym,
      command: command,
      depends_on: dependencies,
      is_autocorrect: is_autocorrect
    )
  end
end

# ============================================================================
# Command Line Options
# ============================================================================

options = {
  autocorrect: false,
  seed: nil,
  verbose: false,
  formatter: nil,
  sections: nil,
  task: nil,
  max_parallel: false,
  fail_fast: false
}

OptionParser.new do |parser|
  parser.banner = "Usage: ./script/test [options]"

  parser.on("-a", "--[no-]autocorrect", "Automatically autocorrects problems") do |v|
    options[:autocorrect] = v
  end

  parser.on("--seed SEED", Integer, "Run tests with specific seed") do |v|
    options[:seed] = v
  end

  parser.on("-v", "--verbose", "Show all command output") do |v|
    options[:verbose] = v
  end

  parser.on("-f", "--formatter FORMATTER", [ :fancy, :simple, :ai ], "Output formatter (fancy, simple, ai)") do |f|
    options[:formatter] = f
  end

  parser.on("-s", "--section SECTION", "Run specific section (e.g., checks, tests)") do |s|
    options[:sections] = [ s ]
  end

  parser.on("-t", "--task TASK", "Run specific task with all its dependencies") do |t|
    options[:task] = t
  end

  parser.on("-P", "--max-parallel", "Run all sections in parallel (dependencies still respected)") do
    options[:max_parallel] = true
  end

  parser.on("-F", "--fail-fast", "Stop starting new tasks after a failure") do
    options[:fail_fast] = true
  end

  parser.on("-L", "--lint", "DEPRECATED: Use --section=checks instead. Only run the checks section") do
    warn "Warning: --lint is deprecated. Use --section=checks instead."
    options[:sections] = [ "checks" ]
  end

  parser.on("-l", "--list") do
    config = load_config
    puts "Available tasks:"
    config["tasks"].each do |name, task_config|
      command = task_config["command"]
      autocorrect_cmd = task_config["autocorrect"]
      dependencies = task_config["depends_on"]

      puts "\n# #{name}"
      puts "$ #{command}"
      puts "  (autocorrect: #{autocorrect_cmd})" if autocorrect_cmd
      puts "  (depends_on: #{Array(dependencies).join(', ')})" if dependencies
    end

    puts "\nAvailable sections:"
    config["sections"].each do |name, section_config|
      puts "\n# #{name}"
      puts "  Tasks: #{section_config['tasks'].join(', ')}"
    end
    exit
  end

  parser.on("-h", "--help", "Prints this help") do
    puts parser
    exit
  end
end.parse!

# Detect accidental filename arguments
if ARGV.any?
  warn "Error: script/test does not accept file arguments."
  warn ""
  warn "To run specific test files, use rspec or cucumber directly:"
  warn "  bin/rspec #{ARGV.first}"
  warn "  bin/cucumber #{ARGV.first}"
  exit 1
end

# ============================================================================
# Main Execution
# ============================================================================

FileUtils.chdir APP_ROOT do
  config = load_config

  # Determine which sections/tasks to run
  if options[:task]
    # Run a single task with its dependencies
    task_list = resolve_task_with_dependencies(options[:task], config)
    sections_to_run = [ "tasks" ]
    # Override sections config with synthetic section containing just this task and dependencies
    config["sections"]["tasks"] = { "tasks" => task_list }
  else
    sections_to_run = options[:sections] || config["sections"].keys
  end

  all_sections_passed = true
  section_results = {}

  # Select formatter
  formatter_type = options[:formatter] || detect_formatter
  formatter = case formatter_type
  when :simple then TestRunner::Formatters::Simple.new(verbose: options[:verbose])
  when :ai then TestRunner::Formatters::Ai.new(verbose: options[:verbose])
  else TestRunner::Formatters::Fancy.new(verbose: options[:verbose])
  end

  # Start formatter once for all sections
  formatter.start

  if options[:max_parallel]
    # Merge all sections into one runner
    all_tasks = sections_to_run
                .flat_map { |name| config["sections"][name]&.dig("tasks") || [] }
                .flat_map { |task| resolve_task_with_dependencies(task, config) }
                .uniq

    formatter.start_section("all")

    runner = TestRunner::Runner.new(formatter: formatter, verbose: options[:verbose], manage_formatter: false, fail_fast: options[:fail_fast])
    register_section_tasks(runner, config, all_tasks, autocorrect: options[:autocorrect], seed: options[:seed], verbose: options[:verbose])
    result = runner.run

    formatter.complete_section("all")

    section_results["all"] = result
    all_sections_passed = result.success?
  else
    # Run each section in order, tracking completed tasks across sections
    completed_task_names = Set.new

    sections_to_run.each do |section_name|
      section_config = config["sections"][section_name]

      if section_config.nil?
        warn "Warning: Section '#{section_name}' not found in configuration"
        next
      end

      # Notify formatter of section start
      formatter.start_section(section_name)

      # Resolve all tasks with their dependencies
      section_tasks = section_config["tasks"]
      all_tasks_with_deps = section_tasks.flat_map { |task| resolve_task_with_dependencies(task, config) }.uniq

      # Run section (formatter lifecycle is managed externally)
      section_runner = TestRunner::Runner.new(formatter: formatter, verbose: options[:verbose], manage_formatter: false, fail_fast: options[:fail_fast])

      # Pre-complete tasks that already succeeded in previous sections
      tasks_to_register = all_tasks_with_deps.reject do |task_name|
        if completed_task_names.include?(task_name.to_sym)
          section_runner.pre_complete_task(name: task_name.to_sym)
          true
        end
      end

      register_section_tasks(section_runner, config, tasks_to_register, autocorrect: options[:autocorrect], seed: options[:seed], verbose: options[:verbose])
      section_result = section_runner.run

      # Track completed tasks for subsequent sections
      section_result.successful_tasks.each { |t| completed_task_names.add(t.name) }

      # Notify formatter of section completion
      formatter.complete_section(section_name)

      # Store result
      section_results[section_name] = section_result

      # Stop if section failed
      if section_result.failed?
        all_sections_passed = false
        break
      end
    end
  end

  formatter.stop

  # Let formatter display failures
  all_failed_tasks = section_results.values.flat_map(&:failed_tasks)
  formatter.print_failures(all_failed_tasks, verbose: options[:verbose])

  # Let formatter print summary
  total_duration = section_results.values.sum(&:total_duration).round(3)
  formatter.print_final_summary(section_results, total_duration: total_duration, all_passed: all_sections_passed)

  abort if !all_sections_passed
end
