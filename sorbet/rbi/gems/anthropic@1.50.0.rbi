            params(
              from: Anthropic::Beta::BetaFallbackInfo::OrHash,
              to: Anthropic::Beta::BetaFallbackInfo::OrHash,
              trigger: Anthropic::Beta::BetaFallbackRefusalTrigger::OrHash,
              type: Symbol
            ).returns(T.attached_class)
          end
