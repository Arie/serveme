  #
  # pkg:gem/async#lib/async/task.rb:57
  def initialize(message = T.unsafe(nil)); end
end

# Represents a flexible timeout that can be rescheduled or extended.
# @public Since *Async v2.24*.
#
# pkg:gem/async#lib/async/timeout.rb:9
class Async::Timeout
  # Initialize a new timeout.
  #
  # pkg:gem/async#lib/async/timeout.rb:11
  def initialize(timers, handle); end

  # Adjust the timeout by the specified duration.
  #
  # The duration is relative to the timeout time, e.g. adjusting the timeout by 5 increases the current duration by 5 seconds.
  #
  # @parameter duration [Numeric] The duration to adjust the timeout by, in seconds.
  # @returns [Numeric] The new time at which the timeout will occur.
  #
  # pkg:gem/async#lib/async/timeout.rb:36
  def adjust(duration); end

  # Cancel the timeout, preventing it from executing.
  #
  # pkg:gem/async#lib/async/timeout.rb:59
  def cancel!; end

  # @returns [Boolean] Whether the timeout has been cancelled.
  #
  # pkg:gem/async#lib/async/timeout.rb:64
  def cancelled?; end

  # @returns [Numeric] The time remaining until the timeout occurs, in seconds.
  #
  # pkg:gem/async#lib/async/timeout.rb:17
  def duration; end

  # Update the duration of the timeout.
  #
  # The duration is relative to the current time, e.g. setting the duration to 5 means the timeout will occur in 5 seconds from now.
  #
  # @parameter value [Numeric] The new duration to assign to the timeout, in seconds.
  #
  # pkg:gem/async#lib/async/timeout.rb:26
  def duration=(value); end

  # @returns [Numeric] The current time in the scheduler, relative to the time of this timeout, in seconds.
  #
  # pkg:gem/async#lib/async/timeout.rb:54
  def now; end

  # @returns [Numeric] The time at which the timeout will occur, in seconds since {now}.
  #
  # pkg:gem/async#lib/async/timeout.rb:41
  def time; end

  # Assign a new time to the timeout, rescheduling it if necessary.
  #
  # @parameter value [Numeric] The new time to assign to the timeout.
  # @returns [Numeric] The new time at which the timeout will occur.
  #
  # pkg:gem/async#lib/async/timeout.rb:49
  def time=(value); end

  private

  # Reschedule the timeout to occur at the specified time.
  #
  # @parameter time [Numeric] The new time to schedule the timeout for.
  # @returns [Numeric] The new time at which the timeout will occur.
  #
  # pkg:gem/async#lib/async/timeout.rb:76
  def reschedule(time); end
end

# Raised when attempting to reschedule a cancelled timeout.
#
# pkg:gem/async#lib/async/timeout.rb:69
class Async::Timeout::CancelledError < ::RuntimeError; end

# Raised if a timeout occurs on a specific Fiber. Handled gracefully by `Task`.
# @public Since *Async v1*.
#
# pkg:gem/async#lib/async/error.rb:9
class Async::TimeoutError < ::StandardError
  # Create a new timeout error.
  #
  # @parameter message [String] The error message.
  #
  # pkg:gem/async#lib/async/error.rb:13
  def initialize(message = T.unsafe(nil)); end
end

# pkg:gem/async#lib/async/version.rb:8
Async::VERSION = T.let(T.unsafe(nil), String)

# Extensions to all Ruby objects.
#
# pkg:gem/async#lib/kernel/async.rb:8
module Kernel
  # Run the given block of code in a task, asynchronously, creating a reactor if necessary.
  #
  # The preferred method to invoke asynchronous behavior at the top level.
  #
  # - When invoked within an existing reactor task, it will run the given block
  # asynchronously. Will return the task once it has been scheduled.
  # - When invoked at the top level, will create and run a reactor, and invoke
  # the block as an asynchronous task. Will block until the reactor finishes
  # running.
  #
  # @yields {|task| ...} The block that will execute asynchronously.
  # 	@parameter task [Async::Task] The task that is executing the given block.
  #
  # @public Since *Async v1*.
  # @asynchronous May block until given block completes executing.
  #
  # pkg:gem/async#lib/kernel/async.rb:24
  def Async(*_arg0, **_arg1, &_arg2); end

  # Create a barrier, yield it to the block, and then wait for all tasks to complete.
  #
  # If no scheduler is running, one will be created automatically for the duration of the block.
  #
  # By default, the barrier uses an `Async::Idler` to manage load, but this can be overridden by providing a different parent or `nil` to disable load management.
  #
  # @parameter parent [Task | Semaphore | Nil] The parent for holding any children tasks.
  # @parameter **options [Hash] Additional options passed to {Kernel::Sync}.
  # @public Since *Async v2.34*.
  #
  # pkg:gem/async#lib/kernel/barrier.rb:20
  def Barrier(parent: T.unsafe(nil), **options); end

  # Run the given block of code synchronously, but within a reactor if not already in one.
  #
  # @yields {|task| ...} The block that will execute asynchronously.
  # 	@parameter task [Async::Task] The task that is executing the given block.
  #
  # @public Since *Async v1*.
  # @asynchronous Will block until given block completes executing.
  #
  # pkg:gem/async#lib/kernel/sync.rb:20
  def Sync(annotation: T.unsafe(nil), &block); end
end
