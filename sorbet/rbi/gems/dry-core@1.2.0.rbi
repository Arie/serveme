  def define_inspect_method; end

  # Define the equalizer methods based on #keys
  #
  # @param [Boolean] inspect whether to define #inspect method
  # @param [Boolean] immutable whether to memoize #hash method
  #
  # @return [undefined]
  #
  # @api private
  #
