# Create a namespace to be imported
#
# @example
#
#   ns = Dry::Core::Container::Namespace.new('name') do
#     register('item', 'item')
#   end
#
#   container = Dry::Core::Container.new
#
#   container.import(ns)
#
#   container.resolve('name.item')
#   => 'item'
#
#
# @api public
#
