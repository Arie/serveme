# Represents a list of keys defined by the DSL
#
# KeyMap objects expose an API for introspecting schema keys and the ability
# to rebuild an input hash using configured coercer function.
#
# Instances of this class are used as the very first step by the schema processors.
#
# @api public
#
# pkg:gem/dry-schema#lib/dry/schema/key_map.rb:15
class Dry::Schema::KeyMap
  include ::Dry::Core::Cache::Methods
  include ::Dry::Core::Equalizer::Methods
  include ::Enumerable
  extend ::Dry::Core::Cache

  # Set key objects
  #
  # @api private
  #
  # pkg:gem/dry-schema#lib/dry/schema/key_map.rb:50
  def initialize(keys); end

  # Return a new key map merged with the provided one
  #
  # @param [KeyMap, Array] other Either a key map or an array with key specs
  #
  # @return [KeyMap]
  #
  # pkg:gem/dry-schema#lib/dry/schema/key_map.rb:117
  def +(other); end

  # Return a new key map that is configured to coerce keys using provided coercer function
  #
  # @return [KeyMap]
  #
  # @api public
  #
  # pkg:gem/dry-schema#lib/dry/schema/key_map.rb:85
  def coercible(&coercer); end

  # Dump keys to their spec format
  #
  # @return [Array]
  #
  # pkg:gem/dry-schema#lib/dry/schema/key_map.rb:131
  def dump; end

  # Iterate over keys
  #
  # @api public
  #
  # pkg:gem/dry-schema#lib/dry/schema/key_map.rb:108
  def each(&_arg0); end

  # Return a string representation of a key map
  #
  # @return [String]
  #
  # pkg:gem/dry-schema#lib/dry/schema/key_map.rb:124
  def inspect; end

  # @return [Array<Key>] A list of defined key objects
  #
  # pkg:gem/dry-schema#lib/dry/schema/key_map.rb:22
  def keys; end

  # Return a new key map with stringified keys
  #
  # A stringified key map is suitable for reading hashes with string keys
  #
  # @return [KeyMap]
  #
  # @api public
  #
  # pkg:gem/dry-schema#lib/dry/schema/key_map.rb:96
  def stringified; end

  # @api private
  #
  # pkg:gem/dry-schema#lib/dry/schema/key_map.rb:101
  def to_dot_notation; end

  # Write a new hash based on the source hash
  #
  # @param [Hash] source The source hash
  # @param [Hash] target The target hash
  #
  # @return [Hash]
  #
  # @api public
  #
  # pkg:gem/dry-schema#lib/dry/schema/key_map.rb:75
  def write(source, target = T.unsafe(nil)); end

  class << self
    # Coerce a list of key specs into a key map
    #
    # @example
    #   KeyMap[:id, :name]
    #   KeyMap[:title, :artist, tags: [:name]]
    #   KeyMap[:title, :artist, [:tags]]
    #
    # @return [KeyMap]
    #
    # @api public
    #
    # pkg:gem/dry-schema#lib/dry/schema/key_map.rb:34
    def [](*keys); end

    # Build new, or returned a cached instance of a key map
    #
    # @param [Array<Symbol>, Array, Hash<Symbol=>Array>] args
    #
    # @return [KeyMap]
    #
    # pkg:gem/dry-schema#lib/dry/schema/key_map.rb:43
    def new(*args); end
  end
end

