  #
  # pkg:gem/geocoder#lib/geocoder/lookups/base.rb:115
  def configuration; end

  # pkg:gem/geocoder#lib/geocoder/lookups/base.rb:327
  def configure_ssl!(client); end

  # Returns a parsed search result (Ruby hash).
  #
  # pkg:gem/geocoder#lib/geocoder/lookups/base.rb:195
  def fetch_data(query); end

  # Fetch a raw geocoding result (JSON string).
  # The result might or might not be cached.
