  # The working Cache object.
  #
  # pkg:gem/geocoder#lib/geocoder/lookups/base.rb:85
  def cache; end

  # Symbol which is used in configuration to refer to this Lookup.
  #
  # pkg:gem/geocoder#lib/geocoder/lookups/base.rb:31
