  # @return [TrueClass, FalseClass] are the URIs equivalent (after normalization)?
  #
  # pkg:gem/http#lib/http/uri.rb:123
  def ==(other); end

  # pkg:gem/http#lib/http/uri.rb:12
  def authority(*_arg0, **_arg1, &_arg2); end

  # pkg:gem/http#lib/http/uri.rb:12
