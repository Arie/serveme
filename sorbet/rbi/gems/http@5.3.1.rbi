# Retriable version of HTTP::Client.
#
# @see http://www.rubydoc.info/gems/http/HTTP/Client
#
# pkg:gem/http#lib/http/retriable/client.rb:10
class HTTP::Retriable::Client < ::HTTP::Client
  # @param [Performer] performer
