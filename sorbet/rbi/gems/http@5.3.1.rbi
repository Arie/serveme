  # @option opts [#call] :uri_normalizer (HTTP::URI::NORMALIZER)
  # @option opts [HTTP::URI, #to_s] :uri
  # @option opts [Hash] :headers
  # @option opts [Hash] :proxy
  # @option opts [String, Enumerable, IO, nil] :body
  #
