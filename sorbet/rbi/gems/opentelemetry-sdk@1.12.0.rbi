  # pkg:gem/opentelemetry-sdk#lib/opentelemetry/sdk/trace/export/batch_span_processor.rb:208
  def report_dropped_spans(dropped_spans, reason:, function: T.unsafe(nil)); end

  # pkg:gem/opentelemetry-sdk#lib/opentelemetry/sdk/trace/export/batch_span_processor.rb:197
