  # pkg:gem/opentelemetry-sdk#lib/opentelemetry/sdk/trace/export/batch_span_processor.rb:174
  def reset_on_fork(restart_thread: T.unsafe(nil)); end

  # pkg:gem/opentelemetry-sdk#lib/opentelemetry/sdk/trace/export/batch_span_processor.rb:156
