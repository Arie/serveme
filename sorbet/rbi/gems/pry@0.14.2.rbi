# pkg:gem/pry#lib/pry/last_exception.rb:12
class Pry::LastException < ::BasicObject
  # pkg:gem/pry#lib/pry/last_exception.rb:15
  def initialize(exception); end

  # pkg:gem/pry#lib/pry/last_exception.rb:13
  def bt_index; end

  # pkg:gem/pry#lib/pry/last_exception.rb:13
