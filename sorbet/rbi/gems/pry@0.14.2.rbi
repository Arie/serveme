# pkg:gem/pry#lib/pry/commands/help.rb:5
class Pry::Command::Help < ::Pry::ClassCommand
  # Get a hash of available commands grouped by the "group" name.
  #
  # pkg:gem/pry#lib/pry/commands/help.rb:29
  def command_groups; end

