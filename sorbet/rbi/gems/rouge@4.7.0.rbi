# pkg:gem/rouge#lib/rouge/token.rb:5
class Rouge::Token
  class << self
    # pkg:gem/rouge#lib/rouge/token.rb:19
    def [](qualname); end

    # pkg:gem/rouge#lib/rouge/token.rb:11
    def cache; end

    # pkg:gem/rouge#lib/rouge/token.rb:62
    def each_token(&b); end

    # pkg:gem/rouge#lib/rouge/token.rb:25
    def inspect; end

    # pkg:gem/rouge#lib/rouge/token.rb:46
    def make_token(name, shortname, &b); end

    # pkg:gem/rouge#lib/rouge/token.rb:29
    def matches?(other); end

    # pkg:gem/rouge#lib/rouge/token.rb:7
    def name; end

    # pkg:gem/rouge#lib/rouge/token.rb:8
    def parent; end

    # pkg:gem/rouge#lib/rouge/token.rb:37
    def qualname; end

    # pkg:gem/rouge#lib/rouge/token.rb:41
    def register!; end

    # pkg:gem/rouge#lib/rouge/token.rb:9
    def shortname; end

    # pkg:gem/rouge#lib/rouge/token.rb:15
    def sub_tokens; end

    # pkg:gem/rouge#lib/rouge/token.rb:57
    def token(name, shortname, &b); end

    # pkg:gem/rouge#lib/rouge/token.rb:33
    def token_chain; end
  end
end

# pkg:gem/rouge#lib/rouge/token.rb:69
module Rouge::Token::Tokens
  class << self
    # pkg:gem/rouge#lib/rouge/token.rb:70
    def token(name, shortname, &b); end
  end
end

