# Transforms a token stream into HTML output.
#
# pkg:gem/rouge#lib/rouge/formatters/html_legacy.rb:7
class Rouge::Formatters::HTMLLegacy < ::Rouge::Formatter
  # @option opts [String] :css_class ('highlight')
  # @option opts [true/false] :line_numbers (false)
  # @option opts [Rouge::CSSTheme] :inline_theme (nil)
  # @option opts [true/false] :wrap (true)
  #
  # Initialize with options.
  #
  # If `:inline_theme` is given, then instead of rendering the
  # tokens as <span> tags with CSS classes, the styles according to
  # the given theme will be inlined in "style" attributes.  This is
  # useful for formats in which stylesheets are not available.
  #
  # Content will be wrapped in a tag (`div` if tableized, `pre` if
  # not) with the given `:css_class` unless `:wrap` is set to `false`.
  #
  # pkg:gem/rouge#lib/rouge/formatters/html_legacy.rb:24
  def initialize(opts = T.unsafe(nil)); end

  # @yield the html output.
  #
  # pkg:gem/rouge#lib/rouge/formatters/html_legacy.rb:37
  def stream(tokens, &b); end
end

