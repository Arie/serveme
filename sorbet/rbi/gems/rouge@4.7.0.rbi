# Transforms a token stream into HTML output.
#
# pkg:gem/rouge#lib/rouge/formatters/html.rb:7
class Rouge::Formatters::HTML < ::Rouge::Formatter
  # pkg:gem/rouge#lib/rouge/formatters/html.rb:29
  def safe_span(tok, safe_val); end

  # pkg:gem/rouge#lib/rouge/formatters/html.rb:23
