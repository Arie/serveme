Rouge::Formatters::Tex::ESCAPE = T.let(T.unsafe(nil), Hash)

# pkg:gem/rouge#lib/rouge/formatters/tex.rb:31
Rouge::Formatters::Tex::ESCAPE_REGEX = T.let(T.unsafe(nil), Regexp)

