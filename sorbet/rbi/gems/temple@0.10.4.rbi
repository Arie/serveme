# @api public
#
# pkg:gem/temple#lib/temple/utils.rb:9
module Temple::Utils
  extend ::Temple::Utils

  # Check if expression is empty
  #
  # @param exp [Array] Temple expression
  # @return true if expression is empty
  #
  # pkg:gem/temple#lib/temple/utils.rb:66
